#!/bin/sh

ABI="$(pkg config ABI 2>/dev/null || pkg -vv 2>/dev/null | awk -F'"' '/ABI =/ {print $2; exit}')"

case "$ABI" in
	FreeBSD:14:amd64|FreeBSD:15:amd64|FreeBSD:16:amd64)
		echo "===> Detected supported OPNsense ABI: $ABI"
		;;
	*)
		echo "===> Unsupported ABI: ${ABI:-unknown}" >&2
		echo "===> Supported: FreeBSD:14/15/16:amd64" >&2
		exit 1
		;;
esac

echo "===> Preparing Lucky runtime"
mkdir -p /etc/rc.conf.d /usr/local/etc/lucky
chmod 0755 /usr/local/bin/lucky /usr/local/etc/rc.d/os-lucky 2>/dev/null || true
chmod 0644 \
	/usr/local/www/lucky.php \
	/usr/local/opnsense/mvc/app/models/OPNsense/Lucky/Menu/Menu.xml \
	/usr/local/opnsense/mvc/app/models/OPNsense/Lucky/ACL/ACL.xml \
	/usr/local/opnsense/service/conf/actions.d/actions_lucky.conf 2>/dev/null || true
printf '%s\n' \
	'lucky_enable="YES"' \
	'lucky_conf_dir="/usr/local/etc/lucky"' \
	'lucky_http_port="16601"' \
	> /etc/rc.conf.d/lucky
touch /var/log/lucky.log 2>/dev/null || true
chmod 0600 /var/log/lucky.log 2>/dev/null || true

echo "===> Clearing OPNsense menu and ACL cache"
rm -f \
	/var/lib/php/tmp/opnsense_menu_cache.xml \
	/var/lib/php/tmp/opnsense_acl_cache.json

echo "===> Reloading OPNsense menu, ACL and configd actions"
service configd restart >/dev/null 2>&1 || true
configctl webgui restart >/dev/null 2>&1 || service lighttpd onerestart >/dev/null 2>&1 || true

echo "===> Starting Lucky service"
service os-lucky onerestart >/dev/null 2>&1 || service os-lucky onestart >/dev/null 2>&1 || true

if service os-lucky onestatus >/dev/null 2>&1; then
	echo "===> Lucky for OPNsense installed. Refresh the browser and open Services > Lucky."
else
	echo "===> Installed, but Lucky did not report running. Check /var/log/lucky.log." >&2
fi

exit 0
